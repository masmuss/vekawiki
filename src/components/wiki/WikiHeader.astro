---
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbList,
  BreadcrumbSeparator,
} from "@/components/ui/breadcrumb";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";
import type { Breadcrumb as BreadcrumbType } from "@/lib/wiki/generate-breadcrumbs";
import { Download } from "@lucide/astro";

interface Props {
  title: string;
  breadcrumbs: BreadcrumbType[];
  growthStage: string;
  updatedAt: Date;
  rawContent?: string;
  downloadFilename?: string;
}

const {
  title,
  breadcrumbs,
  growthStage,
  updatedAt,
  rawContent,
  downloadFilename,
} = Astro.props;

function formatBreadcrumbLabel(label: string): string {
  return label.replace(/-/g, " ");
}

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { dateStyle: "medium" });
}

const showDownload = rawContent && downloadFilename;
---

<header class="mb-10">
  <Breadcrumb class="mb-4">
    <BreadcrumbList>
      <BreadcrumbItem><a href="/">Home</a></BreadcrumbItem>
      <BreadcrumbSeparator />
      {
        breadcrumbs.map((breadcrumb, index) => (
          <>
            <BreadcrumbItem>
              {formatBreadcrumbLabel(breadcrumb.label)}
            </BreadcrumbItem>
            {index < breadcrumbs.length - 1 && <BreadcrumbSeparator />}
          </>
        ))
      }
    </BreadcrumbList>
  </Breadcrumb>
  <h1 class="text-4xl font-bold tracking-tight mb-4">{title}</h1>

  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <Badge variant="secondary">{growthStage}</Badge>
      <span class="text-sm text-muted-foreground">
        Last update on {formatDate(updatedAt)}
      </span>
    </div>
    {
      showDownload && (
        <Button
          as="a"
          href={`data:text/markdown;charset=utf-8,${encodeURIComponent(rawContent)}`}
          download={`${downloadFilename}.md`}
          size="sm"
          variant="secondary"
          class="cursor-pointer"
          title="Download as Markdown"
        >
          <Download class="size-4" />
          <span class="sr-only sm:not-sr-only">Download .md</span>
        </Button>
      )
    }
  </div>

  <Separator />
</header>
